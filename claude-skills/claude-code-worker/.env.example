# Copy this file to `.env` in this skill directory and fill in values.
# `.env` is git-ignored and must never be committed.

# Required. Must point to your private / approved Anthropic-compatible gateway.
# The runner rejects official Anthropic/Claude hosts such as api.anthropic.com
# and claude.ai.
ANTHROPIC_BASE_URL=

# Set one auth variable according to your gateway.
# ANTHROPIC_API_KEY is sent as X-Api-Key by Claude Code.
# ANTHROPIC_AUTH_TOKEN is sent as Authorization: Bearer <value>.
# In --bare mode, the runner adapts ANTHROPIC_AUTH_TOKEN through a temporary
# apiKeyHelper without writing the token into settings.json.
ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=

# Required unless --model or CLAUDE_CODE_WORKER_MODEL is provided.
ANTHROPIC_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
CLAUDE_CODE_SUBAGENT_MODEL=

# Defaults below intentionally suppress non-essential traffic and persistence.
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK=1
CLAUDE_CODE_DISABLE_OFFICIAL_MARKETPLACE_AUTOINSTALL=1
CLAUDE_CODE_SKIP_PROMPT_HISTORY=1
CLAUDE_CODE_DISABLE_AUTO_MEMORY=1
CLAUDE_CODE_DISABLE_BACKGROUND_TASKS=1
CLAUDE_CODE_DISABLE_CLAUDE_MDS=1
DISABLE_AUTOUPDATER=1
DISABLE_UPDATES=1
DISABLE_TELEMETRY=1
DO_NOT_TRACK=1
DISABLE_LOGIN_COMMAND=1
DISABLE_LOGOUT_COMMAND=1

# Optional. Use only for a local unauthenticated gateway.
# CLAUDE_CODE_WORKER_ALLOW_NO_AUTH=1

# Optional. Use when your gateway rejects Claude-specific beta extensions.
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
