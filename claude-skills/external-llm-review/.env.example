# Copy this file to `.env` (in this same skill directory) and fill in your values.
# `.env` MUST be git-ignored and never committed.

# ---------------------------------------------------------------------------
# Backend selection.
#
#   "api"        — raw OpenAI Chat Completions request via httpx (no openai SDK).
#                  Intended for DeepSeek (deepseek-chat / deepseek-reasoner / deepseek-v4-pro).
#   "anthropic"  — raw Anthropic Messages API via httpx with claude-cli/2.1.156 UA
#                  spoofing (borrowed from cache proxy's anthropic-idealab pattern).
#                  Intended for Idealab Anthropic gateway; works with other
#                  Anthropic-compatible gateways that accept sk-ant-* tokens.
#
# reviewer.py defaults to backend=api when this var is unset.
# ---------------------------------------------------------------------------
# EXTERNAL_LLM_REVIEW_BACKEND=api

# ---------------------------------------------------------------------------
# anthropic backend. Used when EXTERNAL_LLM_REVIEW_BACKEND=anthropic.
#
# reviewer.py sends a claude-cli/2.1.156 user-agent (same as the cache proxy)
# so Idealab treats the request like an official claude client.
# ---------------------------------------------------------------------------
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# ---------------------------------------------------------------------------
# api backend (DeepSeek or any OpenAI-compatible endpoint).
# Used when EXTERNAL_LLM_REVIEW_BACKEND=api (the default).
# ---------------------------------------------------------------------------
EXTERNAL_LLM_API_BASE=https://api.deepseek.com
EXTERNAL_LLM_API_KEY=
# Common DeepSeek models: deepseek-chat, deepseek-reasoner, deepseek-v4-pro
EXTERNAL_LLM_MODEL=
