# Copy this file to `.env` (in this same skill directory) and fill in your values.
# `.env` MUST be git-ignored and never committed.

# Endpoint base URL（依 EXTERNAL_LLM_API_FORMAT 取值）。
#
# OpenAI 兼容协议（chat / responses）—— SDK 会拼 /chat/completions 或 /responses：
#   DeepSeek:               https://api.deepseek.com
#   Zhipu (智谱):           https://open.bigmodel.cn/api/paas/v4
#   本地 Ollama:            http://localhost:11434/v1
#   任何 OpenAI Chat Completions 兼容网关
#
# Anthropic 协议（anthropic）—— SDK 自动拼 /v1/messages，base **不**带 /v1：
#   官方:                   https://api.anthropic.com
#   自定义 Anthropic 兼容网关（与 Claude Code 本身用的网关同源即可）
EXTERNAL_LLM_API_BASE=

# API key / access token for the endpoint.
EXTERNAL_LLM_API_KEY=

# Model name. 取决于上面 endpoint 支持哪些模型。常见：
#   deepseek-chat / deepseek-reasoner
#   glm-4-plus
#   llama3:70b              (Ollama 本地)
#   claude-opus-4-... / claude-sonnet-4-...   (Anthropic 兼容网关)
EXTERNAL_LLM_MODEL=

# API protocol shape:
#   "chat"       — OpenAI Chat Completions  (POST <base>/chat/completions)，默认
#   "responses"  — OpenAI Responses API     (POST <base>/responses)
#   "anthropic"  — Anthropic Messages API   (POST <base>/v1/messages，SDK 自动拼 /v1/messages)
# 不同 endpoint 暴露的协议不同，且常分别计 quota / rate-limit；遇 404/429 可切换。
# anthropic 路径要求 base 不带 /v1。
EXTERNAL_LLM_API_FORMAT=chat

# Prompt cache mode:
#   "off"           — 默认，不发送任何 cache_control 扩展，兼容所有 OpenAI-like endpoint
#   "qwen-explicit" — Qwen / DashScope OpenAI-compatible Chat Completions 显式缓存
#
# qwen-explicit 只支持 EXTERNAL_LLM_API_FORMAT=chat。它会缓存稳定上下文
#（系统评审规则、--spec、--cache-prefix），默认不缓存 git diff。
EXTERNAL_LLM_CACHE_MODE=off

# 默认 false。仅当同一个任务需要围绕同一份 diff 多轮 review/追问时打开。
# 也可以用 CLI 参数 --cache-diff 临时启用。
EXTERNAL_LLM_CACHE_DIFF=false
