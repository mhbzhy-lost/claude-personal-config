# Copy this file to `.env` (in this same skill directory) and fill in your values.
# `.env` MUST be git-ignored and never committed.

# ---------------------------------------------------------------------------
# Backend selection.
#
#   "api"             — raw OpenAI Chat Completions request. Intended for
#                       DeepSeek (deepseek-chat / deepseek-reasoner / deepseek-v4-pro).
#                       Other OpenAI-compatible endpoints may technically work
#                       but are NOT supported defaults.
#   "claude-code-cli" — call the local `claude` CLI against an Anthropic-compatible
#                       gateway. Use only when raw SDK requests are blocked but
#                       the gateway is reachable through Claude Code.
#
# reviewer.py defaults to backend=api when this var is unset. Set it explicitly
# only if your machine should default to claude-code-cli.
# ---------------------------------------------------------------------------
# EXTERNAL_LLM_REVIEW_BACKEND=claude-code-cli

# ---------------------------------------------------------------------------
# claude-code-cli backend (Claude / Sonnet / Opus / Haiku models only).
#
# Initialize the target machine once:
#   command -v claude >/dev/null || npm install -g @anthropic-ai/claude-code
#   claude --version
# ---------------------------------------------------------------------------
ANTHROPIC_BASE_URL=
# Use either ANTHROPIC_API_KEY or ANTHROPIC_AUTH_TOKEN per your gateway:
#   - Anthropic-style sk-ant-* tokens          → ANTHROPIC_API_KEY
#   - Enterprise gateway opaque tokens / PATs  → ANTHROPIC_AUTH_TOKEN
ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_MODEL is gateway-specific; check your gateway's model catalog.
ANTHROPIC_MODEL=
# EXTERNAL_LLM_CLAUDE_BIN=claude
# EXTERNAL_LLM_CLAUDE_TIMEOUT_SECONDS=300

# ---------------------------------------------------------------------------
# api backend (DeepSeek). Used only when EXTERNAL_LLM_REVIEW_BACKEND=api.
# ---------------------------------------------------------------------------
EXTERNAL_LLM_API_BASE=https://api.deepseek.com
EXTERNAL_LLM_API_KEY=
# Common DeepSeek models: deepseek-chat, deepseek-reasoner, deepseek-v4-pro
EXTERNAL_LLM_MODEL=
