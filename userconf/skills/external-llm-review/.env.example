# external-llm-review secrets (.env) — gitignored.
#
# Architecture: provider-specific YAMLs live in ``providers/`` and define
# non-secret config (base_url, model, max_tokens, feature flags). Secrets
# are referenced there via ``${VAR}`` placeholders and resolved at runtime
# from this file.
#
# To switch providers, set ``EXTERNAL_LLM_REVIEW_PROVIDER=<name>``
# (matches ``providers/<name>.yaml``), or pass ``--provider <name>`` on CLI.

# Anthropic idealab gateway (providers/idealab-anthropic.yaml)
ANTHROPIC_API_KEY=

# OpenAI-compatible idealab gateway (providers/idealab-openai.yaml)
IDEALAB_OPENAI_API_KEY=

# Bailian / DashScope Qwen (providers/bailian.yaml)
BAILIAN_API_KEY=
