{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenCode DeepSeek Worker Prompt Capsule",
  "type": "object",
  "additionalProperties": false,
  "required": ["objective"],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "allowed_write_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "read_context": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "validation": {
      "type": "string",
      "default": ""
    },
    "notes": {
      "type": "string",
      "default": ""
    }
  }
}
