{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Code Worker Task Capsule",
  "type": "object",
  "additionalProperties": false,
  "required": ["objective", "allowed_write_scope", "constraints"],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "read_context": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_write_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation": {
      "type": "string"
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
