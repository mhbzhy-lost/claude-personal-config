{
  "description": "OpenCode global permission policy. See opencode-permission.jsonc for the human-annotated version with rationale comments. Init_opencode.sh reads this file and deep-merges the template into opencode.json.",
  "notes": [
    "opencode permission evaluation: LAST matching rule wins. Order of keys within an object matters.",
    "Put broad wildcard rules FIRST, then increasingly specific rules; the most specific (last) rule overrides the default.",
    "Pattern keys are globs on tool arguments: '*' means any invocation of that tool; 'git push*' means command string starts with 'git push'."
  ],
  "template": {
    "glob": "allow",
    "grep": "allow",
    "read": {
      "*": "allow",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.config/gh/**": "ask",
      "~/.npmrc": "ask",
      "~/.pypirc": "ask",
      "~/.netrc": "ask",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/id_rsa": "deny",
      "**/id_ed25519": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*.env.example": "allow"
    },
    "edit": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "lsp": "allow",
    "doom_loop": "ask",
    "external_directory": "ask",
    "skill": "allow",
    "bash": {
      "*": "ask",

      "pwd": "allow",
      "ls*": "allow",
      "find*": "allow",
      "cat*": "allow",
      "sed*": "allow",
      "awk*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "wc*": "allow",
      "file*": "allow",
      "which*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git grep*": "allow",
      "git ls-files*": "allow",
      "git fetch*": "allow",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",

      "npm test*": "allow",
      "npm run *": "allow",
      "npm ci": "allow",
      "npm install": "ask",
      "npm install *": "ask",
      "npm version*": "ask",
      "npm link*": "ask",
      "npm publish*": "deny",
      "pnpm test*": "allow",
      "pnpm run *": "allow",
      "pnpm install": "ask",
      "pnpm install *": "ask",
      "pnpm publish*": "deny",
      "yarn test*": "allow",
      "yarn run *": "allow",
      "yarn install": "ask",
      "bun test*": "allow",
      "bun run *": "allow",
      "bun install": "ask",
      "make test*": "allow",
      "make build*": "allow",
      "cargo check*": "allow",
      "cargo test*": "allow",
      "cargo build*": "allow",
      "go test*": "allow",
      "go build*": "allow",
      "python -m pytest*": "allow",
      "pytest*": "allow",

      "sudo *": "deny",
      "su *": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "diskutil *": "deny",
      "rm -rf *": "deny",
      "chmod *": "ask",
      "chown *": "ask",
      "rm *": "ask",
      "mv *": "ask",
      "cp *": "ask",
      "mount *": "ask",
      "umount *": "ask",
      "kill *": "ask",
      "killall *": "ask",

      "curl *|*sh*": "deny",
      "wget *|*sh*": "deny",
      "curl *": "ask",
      "wget *": "ask",
      "ssh *": "ask",
      "scp *": "ask",
      "rsync *": "ask",

      "docker *": "ask",
      "docker compose *": "ask",
      "kubectl *": "ask",
      "helm *": "ask",
      "terraform *": "ask",
      "aws *": "ask",
      "gcloud *": "ask",
      "az *": "ask",
      "vercel *": "ask",
      "netlify *": "ask",
      "flyctl *": "ask",
      "prisma migrate deploy*": "ask",
      "prisma migrate reset*": "deny",

      "git clean*": "deny"
    }
  }
}
