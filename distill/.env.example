# Skill distillation pipeline configuration
# Copy this file to .env and fill in your keys
# (.env is git-ignored — never commit it)

# Required: pick provider for this run
# Options: deepseek | qwen
DISTILL_PROVIDER=deepseek

# Required when DISTILL_PROVIDER=deepseek
# Get key from https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Required when DISTILL_PROVIDER=qwen
# Get key from https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=

# Optional: override default model
# DISTILL_MODEL=deepseek-v4-pro
# DISTILL_MODEL=qwen3.6-max-preview
