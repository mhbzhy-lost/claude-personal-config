{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|apply_patch|functions.apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__CLAUDE_CONFIG_HOME__/codex/hooks/coding-guard.sh\"",
            "statusMessage": "Checking TDD and bugfix workflow"
          }
        ]
      },
      {
        "matcher": "mcp__skill-catalog__resolve",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__CLAUDE_CONFIG_HOME__/codex/hooks/skill-resolve-preflight.sh\"",
            "statusMessage": "Checking skill-catalog resolve inputs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__CLAUDE_CONFIG_HOME__/shared/hooks/external-review-gate.sh\"",
            "timeout": 600,
            "statusMessage": "Running external review gate..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__CLAUDE_CONFIG_HOME__/codex/hooks/git-commit-hint.sh\"",
            "statusMessage": "Checking git commit workflow"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__CLAUDE_CONFIG_HOME__/codex/hooks/external-llm-review-permission.sh\"",
            "statusMessage": "Checking external LLM review approval"
          }
        ]
      }
    ]
  }
}
