# Copy to .env for local dev. Never commit .env.
{{ENV_PREFIX}}_DATABASE_URL=postgresql+asyncpg://{{ENV_PREFIX_LOWER}}:{{ENV_PREFIX_LOWER}}@localhost:{{POSTGRES_PORT}}/{{ENV_PREFIX_LOWER}}
{{ENV_PREFIX}}_DATABASE_URL_TEST=postgresql+asyncpg://{{ENV_PREFIX_LOWER}}:{{ENV_PREFIX_LOWER}}@localhost:{{POSTGRES_PORT}}/{{ENV_PREFIX_LOWER}}_test

{{ENV_PREFIX}}_AUTH_MODE=dev
{{ENV_PREFIX}}_JWT_PUBLIC_KEY=
{{ENV_PREFIX}}_JWT_ALGORITHM=RS256
{{ENV_PREFIX}}_JWT_AUDIENCE=
{{ENV_PREFIX}}_JWT_ISSUER=

{{ENV_PREFIX}}_HOST=0.0.0.0
{{ENV_PREFIX}}_PORT={{BACKEND_PORT}}
{{ENV_PREFIX}}_LOG_LEVEL=INFO
{{ENV_PREFIX}}_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
