{
  "schema_version": 1,
  "slug": "top-navbar",
  "title": "顶部导航条",
  "title_en": "Top NavBar",
  "description": "顶部导航条 UI chrome：返回 / 标题 / 右槽 1:2:1 grid，iOS safe-area-inset 适配，transparent 模式。",
  "kind": "ui-chrome",
  "capabilities": [
    "ui-chrome",
    "navigation",
    "mobile-friendly"
  ],
  "tech_stack": ["react", "antd", "wechat-miniprogram", "taro"],
  "copyable_root": "component",
  "consumer_readme": "component/README.md",
  "frontend": {
    "path": "component/frontend",
    "package_name": "@ui/top-navbar",
    "main_exports": ["NavBar", "NavBarPage"]
  },
  "miniprogram": {
    "path": "component/miniprogram",
    "package_name": "@tn/top-navbar-mp",
    "main_exports": ["NavBar", "NavBarPage"]
  },
  "anti_use_cases": [
    "移动端 tab 切换 → mobile-tabbar",
    "桌面 admin 框架 → antd Layout / ProLayout"
  ],
  "related_blocks": ["mobile-tabbar"]
}
