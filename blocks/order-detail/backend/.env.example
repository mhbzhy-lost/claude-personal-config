# Copy to .env for local dev. Never commit .env.
OD_DATABASE_URL=postgresql+asyncpg://od:od@localhost:5546/od
OD_DATABASE_URL_TEST=postgresql+asyncpg://od:od@localhost:5546/od_test

OD_AUTH_MODE=dev
OD_JWT_PUBLIC_KEY=
OD_JWT_ALGORITHM=RS256
OD_JWT_AUDIENCE=
OD_JWT_ISSUER=

OD_HOST=0.0.0.0
OD_PORT=8082
OD_LOG_LEVEL=INFO
OD_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
