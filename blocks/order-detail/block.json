{
  "schema_version": 1,
  "slug": "order-detail",
  "title": "订单列表 + 详情",
  "title_en": "Order Detail",
  "description": "订单列表 + 详情页：状态机驱动（pending→paid→shipped→delivered）+ 取消 / 申请退款（Modal 二次确认）。必登录。",
  "kind": "business-pattern",
  "capabilities": [
    "list-view",
    "detail-view",
    "master-detail",
    "split-view",
    "state-machine",
    "auth-required",
    "order-management",
    "filtering",
    "modal-confirm"
  ],
  "tech_stack": ["react", "antd", "fastapi", "postgres"],
  "copyable_root": "component",
  "consumer_readme": "component/README.md",
  "frontend": {
    "path": "component/frontend",
    "package_name": "@od/order-detail",
    "main_exports": ["OrderList", "OrderDetail", "OrderMasterDetail"]
  },
  "backend": {
    "path": "component/backend",
    "env_prefix": "OD",
    "http_port": 8082,
    "postgres_port": 5546
  },
  "protocol": {
    "path": "component/protocol",
    "openapi": "component/protocol/openapi.yaml"
  },
  "anti_use_cases": [
    "商品列表 → commerce-product-list",
    "购物车结算 → cart-checkout（待建）",
    "支付宝/微信支付集成（host 侧职责）"
  ],
  "related_blocks": ["commerce-product-list", "master-detail"]
}
