{
  "schema_version": 1,
  "slug": "im-chat-detail",
  "title": "双人对话详情",
  "title_en": "1-on-1 Chat Detail",
  "description": "双人聊天页：气泡左右分发 + WS 实时收发 + 已读 ✓✓ + 撤回 + cursor 分页加载更早消息。",
  "kind": "business-pattern",
  "capabilities": [
    "detail-view",
    "realtime",
    "websocket",
    "pagination-cursor",
    "soft-delete",
    "state-machine",
    "auth-required",
    "1-on-1-chat"
  ],
  "tech_stack": ["react", "antd", "fastapi", "postgres", "websocket", "wechat-miniprogram", "taro"],
  "copyable_root": "component",
  "consumer_readme": "component/README.md",
  "frontend": {
    "path": "component/frontend",
    "package_name": "@chat/im-chat-detail",
    "main_export": "ChatDetail"
  },
  "backend": {
    "path": "component/backend",
    "env_prefix": "CHAT",
    "http_port": 8084,
    "postgres_port": 5548
  },
  "protocol": {
    "path": "component/protocol",
    "openapi": "component/protocol/openapi.yaml"
  },
  "anti_use_cases": [
    "多会话列表 → im-conversation-list",
    "群聊（≥3 人）→ im-group-chat（待建）",
    "嵌入式评论 → comment-thread",
    "客服分配/工单 → support-ticket（待建）"
  ],
  "related_blocks": ["im-conversation-list"],
  "miniprogram": {
    "path": "component/miniprogram",
    "package_name": "@chat/im-chat-detail-mp",
    "main_export": "ChatDetail"
  }
}
