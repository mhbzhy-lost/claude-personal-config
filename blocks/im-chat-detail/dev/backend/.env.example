# Copy to .env for local dev. Never commit .env.
CHAT_DATABASE_URL=postgresql+asyncpg://chat:chat@localhost:5548/chat
CHAT_DATABASE_URL_TEST=postgresql+asyncpg://chat:chat@localhost:5548/chat_test

CHAT_AUTH_MODE=dev
CHAT_JWT_PUBLIC_KEY=
CHAT_JWT_ALGORITHM=RS256
CHAT_JWT_AUDIENCE=
CHAT_JWT_ISSUER=

CHAT_HOST=0.0.0.0
CHAT_PORT=8084
CHAT_LOG_LEVEL=INFO
CHAT_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
