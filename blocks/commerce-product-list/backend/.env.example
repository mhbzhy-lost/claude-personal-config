# Copy to .env for local dev. Never commit .env.
CPL_DATABASE_URL=postgresql+asyncpg://cpl:cpl@localhost:5545/cpl
CPL_DATABASE_URL_TEST=postgresql+asyncpg://cpl:cpl@localhost:5545/cpl_test

CPL_AUTH_MODE=dev
CPL_JWT_PUBLIC_KEY=
CPL_JWT_ALGORITHM=RS256
CPL_JWT_AUDIENCE=
CPL_JWT_ISSUER=

CPL_HOST=0.0.0.0
CPL_PORT=8081
CPL_LOG_LEVEL=INFO
CPL_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5176
