# Copy to .env for local dev. Never commit .env.
CT_DATABASE_URL=postgresql+asyncpg://ct:ct@localhost:5547/ct
CT_DATABASE_URL_TEST=postgresql+asyncpg://ct:ct@localhost:5547/ct_test

CT_AUTH_MODE=dev
CT_JWT_PUBLIC_KEY=
CT_JWT_ALGORITHM=RS256
CT_JWT_AUDIENCE=
CT_JWT_ISSUER=

CT_HOST=0.0.0.0
CT_PORT=8083
CT_LOG_LEVEL=INFO
CT_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
