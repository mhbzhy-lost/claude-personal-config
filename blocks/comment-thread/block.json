{
  "schema_version": 1,
  "slug": "comment-thread",
  "title": "嵌入式评论流",
  "title_en": "Comment Thread (Embeddable Widget)",
  "description": "嵌入式评论 widget：树状 reply（最多 3 层）+ 软指针 host（resource_type+resource_id 锚到任意业务实体）+ 匿名可读、登录可写。",
  "kind": "business-pattern",
  "capabilities": [
    "embedded-widget",
    "tree-structure",
    "soft-delete",
    "anonymous-readable",
    "comment-discussion",
    "mixed-auth"
  ],
  "tech_stack": ["react", "antd", "fastapi", "postgres", "wechat-miniprogram", "taro"],
  "copyable_root": "component",
  "consumer_readme": "component/README.md",
  "frontend": {
    "path": "component/frontend",
    "package_name": "@ct/comment-thread",
    "main_export": "CommentsThread"
  },
  "backend": {
    "path": "component/backend",
    "env_prefix": "CT",
    "http_port": 8083,
    "postgres_port": 5547
  },
  "protocol": {
    "path": "component/protocol",
    "openapi": "component/protocol/openapi.yaml"
  },
  "anti_use_cases": [
    "IM 多对话列表 → im-conversation-list",
    "通知中心 → notification-center（待建）",
    "论坛主题列表 + 详情双视图 → forum-thread（待建）",
    "实时聊天室 → im-chat-detail"
  ],
  "related_blocks": [],
  "miniprogram": {
    "path": "component/miniprogram",
    "package_name": "@ct/comment-thread-mp",
    "main_export": "CommentsThread"
  }
}
