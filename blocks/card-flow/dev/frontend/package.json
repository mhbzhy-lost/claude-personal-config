{
  "name": "@cf/card-flow-dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Dev tooling for @cf/card-flow SDK (typecheck + a11y lint + optional lib build).",
  "scripts": {
    "typecheck": "tsc -p ../../component/frontend/tsconfig.json --noEmit",
    "lint:a11y": "cd ../../component/frontend && pnpm exec eslint src --max-warnings 0",
    "build": "vite build && tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.3",
    "antd": "^5.22.0",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-css-injected-by-js": "^5.0.1"
  }
}
