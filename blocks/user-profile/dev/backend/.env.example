# Copy to .env for local dev. Never commit .env.
UP_DATABASE_URL=postgresql+asyncpg://up:up@localhost:5551/up
UP_DATABASE_URL_TEST=postgresql+asyncpg://up:up@localhost:5551/up_test

UP_AUTH_MODE=dev
UP_JWT_PUBLIC_KEY=
UP_JWT_ALGORITHM=RS256
UP_JWT_AUDIENCE=
