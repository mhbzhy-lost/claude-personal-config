{
  "schema_version": 1,
  "slug": "user-profile",
  "title": "用户主页",
  "title_en": "User Profile",
  "description": "用户主页形态参考:cover + 头像(覆叠 cover)+ 名/认证/handle/bio + 位置/网站/加入时间 + stats 矩阵 + 关注/编辑动作 + tabs(host 注入内容)。前端完整,后端可启动 stub。",
  "kind": "business-pattern",
  "capabilities": [
    "detail-view",
    "user-profile",
    "social",
    "tabs",
    "follow-action",
    "stats-display",
    "auth-optional"
  ],
  "tech_stack": ["react", "antd", "fastapi", "postgres"],
  "copyable_root": "component",
  "consumer_readme": "component/README.md",
  "frontend": {
    "path": "component/frontend",
    "package_name": "@up/user-profile",
    "main_export": "UserProfile"
  },
  "backend": {
    "path": "component/backend",
    "env_prefix": "UP",
    "http_port": 8087,
    "postgres_port": 5551
  },
  "protocol": {
    "path": "component/protocol",
    "openapi": "component/protocol/openapi.yaml"
  },
  "anti_use_cases": [
    "后台用户管理(列表/筛选) → data-table",
    "登录/注册/找回密码 → 待建 auth-flow",
    "用户资料编辑表单 → host 自己拼(本块只触发 onEdit)",
    "聊天对手资料浮卡 → 用 antd Popover 自己拼"
  ],
  "related_blocks": ["im-chat-detail", "comment-thread"]
}
