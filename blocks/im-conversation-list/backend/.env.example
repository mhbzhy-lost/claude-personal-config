# Copy to .env for local dev. Never commit .env.

# Database
IMCL_DATABASE_URL=postgresql+asyncpg://imcl:imcl@localhost:5544/imcl
IMCL_DATABASE_URL_TEST=postgresql+asyncpg://imcl:imcl@localhost:5544/imcl_test

# Auth
# dev: trusts X-Dev-User-Id header (NEVER enable in prod)
# jwt: validates Bearer JWT against IMCL_JWT_PUBLIC_KEY
IMCL_AUTH_MODE=dev
IMCL_JWT_PUBLIC_KEY=
IMCL_JWT_ALGORITHM=RS256
IMCL_JWT_AUDIENCE=
IMCL_JWT_ISSUER=

# Server
IMCL_HOST=0.0.0.0
IMCL_PORT=8080
IMCL_LOG_LEVEL=INFO
IMCL_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
