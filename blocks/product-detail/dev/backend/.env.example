# Copy to .env for local dev. Never commit .env.
PD_DATABASE_URL=postgresql+asyncpg://pd:pd@localhost:5550/pd
PD_DATABASE_URL_TEST=postgresql+asyncpg://pd:pd@localhost:5550/pd_test

PD_AUTH_MODE=dev
PD_JWT_PUBLIC_KEY=
PD_JWT_ALGORITHM=RS256
PD_JWT_AUDIENCE=
PD_JWT_ISSUER=

PD_HOST=0.0.0.0
PD_PORT=8086
PD_LOG_LEVEL=INFO
PD_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
